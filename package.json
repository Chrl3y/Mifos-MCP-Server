{
  "name": "mifos-system-doctor",
  "version": "1.0.0",
  "description": "Unified MCP Server — System Doctor for Mifos X / Apache Fineract / Helaplus. Audit, fix, automate, notify, report and control your microfinance platform.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "webhook": "tsx src/webhook-server/index.ts",
    "dashboard": "cd dashboard && npm run dev",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.10",
    "express": "^4.18.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": { "node": ">=20" },
  "keywords": ["mifos", "fineract", "microfinance", "mcp", "helaplus", "nova"],
  "license": "MPL-2.0"
}
