# ─── Fineract / Helaplus Core API ─────────────────────────────────────────────
FINERACT_BASE_URL=http://localhost:8080/fineract-provider/api/v1
FINERACT_TENANT_ID=default
FINERACT_USERNAME=mifos
FINERACT_PASSWORD=password

# ─── Institution Settings ─────────────────────────────────────────────────────
INSTITUTION_NAME=Nova Microfinance
INSTITUTION_CURRENCY=UGX
INSTITUTION_LOCALE=en_UG

# ─── Notification: Africa's Talking (SMS & WhatsApp) ─────────────────────────
# Sign up at https://africastalking.com — cheapest Uganda SMS & WhatsApp
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
AT_SENDER_ID=NOVA                    # SMS sender name (max 11 chars)
AT_WHATSAPP_NUMBER=+256XXXXXXXXX     # Your WhatsApp Business number

# ─── Notification: Twilio (WhatsApp fallback) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Notification Channel Preference ─────────────────────────────────────────
# 'sms' | 'whatsapp' | 'both'
DEFAULT_NOTIFICATION_CHANNEL=whatsapp

# ─── Webhook Server ───────────────────────────────────────────────────────────
WEBHOOK_PORT=4000
WEBHOOK_SECRET=your_webhook_secret_token

# ─── Dashboard API ────────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_API_SECRET=your_dashboard_api_secret

# ─── Issue Register ───────────────────────────────────────────────────────────
# Path to issues-register.json (defaults to bundled file)
ISSUES_REGISTER_PATH=./src/config/issues-register.json
